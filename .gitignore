# Firebase
.firebase/
*-debug.log
.runtimeconfig.json
serviceAccountKey.json
serviceAccount*.json

# Print-resolution source photos (Q3 2025). Only the optimised webp output in
# public/img/hires/ (generated by scripts/import-hires.mjs) is committed/deployed.
High-res photos and logos-Q3 2025/

# Background-less (transparent cut-out) product images are not shipped — only
# photos that have a real background are kept. import-hires.mjs already skips
# these; this is a guard against any being committed by hand.
**/*-transparent*.webp
**/*transparentpng*.webp

# Local image backup + generated upload manifest. Images now live in Firebase
# Storage (uploaded by scripts/upload-images-to-storage.mjs); these folders are
# the local source/backup used to (re)upload, not shipped or committed.
image-store/
image-store-tmp/
scripts/image-manifest.json

# Dev comparison screenshots (generated during review cycles — not shipped)
review-images/

# Graphify knowledge graph output (re-run /graphify to regenerate)
graphify-out/

# Root-level Puppeteer screenshot / debug scripts used during development
_*.mjs

# Old Express server (pre-Firebase; superseded by direct Firebase SDK)
server/

# One-time migration / ops scripts (local tools only, not part of the deployed app)
scripts/

# Development planning and migration notes
MIGRATION_PLAN.md

